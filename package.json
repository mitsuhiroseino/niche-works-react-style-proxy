{
  "name": "@niche-works/react-style-proxy",
  "version": "0.1.0",
  "keywords": [
    "react",
    "emotion",
    "style"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiroseino/niche-works-react-style-proxy.git"
  },
  "license": "MIT",
  "author": "Mitsuhiro Seino",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./constants": "./src/constants.ts",
    "./*/constants": "./src/*/constants.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "indexes": "tsx scripts/indexes.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "tidy": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" --config ./prettier.tidy.config.ts"
  },
  "dependencies": {
    "@niche-works/types": "^0.1.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@niche-works/dev": "^0.4.0",
    "@niche-works/rollup-plugin-dist-package": "^0.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "react": "^17.0.0",
    "react-dom": "^17.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
